void motorMoveAllTime(uint8_t speed, bool spinRight)
{
	MOTOR_spin_right = spinRight;
#if DRIVER_MOTOR==DRIVER1_L9110S
	motorMoveAllTimeL9110S(speed, spinRight);
#endif
#if DRIVER_MOTOR==DRIVER2_L298N
	motorMoveAllTimeL298N(speed, spinRight);
